# Copy to .env, review every value for this host, then keep .env mode 600.
# This template contains build configuration only; do not add credentials.

# Repository root, build identity, isolated Python environment, artifacts, and lifecycle switches.
: "${ROOT_DIR:=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)}"
BUILD_NUMBER=$(date +%Y%m%d)
VENV_DIR="${ROOT_DIR}/.venv"
PYTHON="${VENV_DIR}/bin/python"
PYTHON_VERSION=3.13
BUILD_CONSTRAINTS_FILE="${ROOT_DIR}/requirements/build.lock"
DIST_DIR="${ROOT_DIR}/dist"
MAX_JOBS=16
USE_CLANG=1
USE_CCACHE=1
CLEAR_PIP_CACHE=0
CLEAN_BUILD=1
VERIFY_INSTALL=1
INSTALL_BUILD_PYTHON_DEPS=1

# Local source checkouts used by the five fixed build stages.
PYTORCH_SOURCE_DIR="${ROOT_DIR}/pytorch"
VISION_SOURCE_DIR="${ROOT_DIR}/vision"
AUDIO_SOURCE_DIR="${ROOT_DIR}/audio"
TRITON_SOURCE_DIR="${ROOT_DIR}/triton"
FLASH_ATTENTION_SOURCE_DIR="${ROOT_DIR}/flash-attention"
FLASH_ATTENTION_CUTE_SOURCE_DIR="${FLASH_ATTENTION_SOURCE_DIR}/flash_attn/cute"
FLASH_ATTENTION_WHEEL_DIR="${DIST_DIR}"

# CUDA, MPI, codec, and LLVM toolchain locations. Review for this host.
CUDA_HOME=/usr/local/cuda-13.3
MAGMA_ROOT=/usr/local/magma
OPENMPI_ROOT=/usr/local/ompi
NVCODEC_HOME=/usr/local/nvcodec
LLVM_CONFIG_PATH=/usr/lib/llvm-21/bin/llvm-config

# Package versions used to name locally built wheels. Review against submodule revisions.
PYTORCH_BUILD_VERSION=2.14.0a0
VISION_BUILD_VERSION=0.29.0a0
AUDIO_BUILD_VERSION=2.11.0a0

# Log filenames are relative to the repository root.
MAIN_LOG_FILE=alltorch_build.log
TRITON_BUILD_LOG_FILE=triton_build.log
PYTORCH_BUILD_LOG_FILE=pytorch_build.log
FLASH_ATTENTION_BUILD_LOG_FILE=flash_attention_build.log
VISION_BUILD_LOG_FILE=vision_build.log
AUDIO_BUILD_LOG_FILE=audio_build.log

# Build tools, compiler selection, and optional compiler cache.
BUILD_PKG_CONFIG_PREFIX=/usr/local/lib/pkgconfig
GCC_COMMAND=gcc
GXX_COMMAND=g++
CLANG_COMMAND=clang-21
CLANGXX_COMMAND=clang++-21
CMAKE_COMMAND=cmake
NINJA_COMMAND=ninja
NVCC_COMMAND=nvcc
NVIDIA_SMI_COMMAND=nvidia-smi
CCACHE_COMMAND=ccache

# Project-local build and package caches. Triton downloads its pinned LLVM under TRITON_HOME.
XDG_CACHE_HOME="${ROOT_DIR}/.build/xdg-cache"
UV_CACHE_DIR="${ROOT_DIR}/.build/uv-cache"
PIP_CACHE_DIR="${ROOT_DIR}/.build/pip-cache"
TMPDIR="${ROOT_DIR}/.build/tmp"
PYTHONPYCACHEPREFIX="${ROOT_DIR}/.build/python-cache"

# Triton build paths, wheel identity, and build feature switches.
TRITON_HOME="${ROOT_DIR}/.build/triton-home"
TRITON_CACHE_DIR="${ROOT_DIR}/.build/triton-kernel-cache"
TRITON_CUPTI_INCLUDE_PATH="$CUDA_HOME/include"
TRITON_CUPTI_LIB_PATH="$CUDA_HOME/lib64"
TRITON_LIBDEVICE_PATH="$CUDA_HOME/nvvm/libdevice"
TRITON_LIBCUDA_PATH="$CUDA_HOME/lib64"
TRITON_PTXAS_PATH="$CUDA_HOME/bin/ptxas"
TRITON_CUOBJDUMP_PATH="$CUDA_HOME/bin/cuobjdump"
TRITON_NVDISASM_PATH="$CUDA_HOME/bin/nvdisasm"
TRITON_WHEEL_NAME=pytorch-triton
TRITON_WHEEL_VERSION_SUFFIX=".post${BUILD_NUMBER}"
TRITON_BUILD_WITH_CCACHE=1
TRITON_PARALLEL_LINK_JOBS="$MAX_JOBS"
TRITON_OFFLINE_BUILD=0
TRITON_BUILD_PROTON=0
TRITON_BUILD_UT=0

# PyTorch CMake feature switches.
PYTORCH_USE_NATIVE_ARCH=1
PYTORCH_USE_CUDA=1
PYTORCH_USE_CUDNN=1
PYTORCH_USE_NCCL=1
PYTORCH_USE_CUSPARSELT=1
PYTORCH_CUSPARSELT_INCLUDE_DIR=/usr/include/libcusparseLt/13
PYTORCH_CUSPARSELT_LIBRARY=/usr/lib/x86_64-linux-gnu/libcusparseLt/13
PYTORCH_USE_CUDSS=0
PYTORCH_USE_CUFILE=1
PYTORCH_USE_MKLDNN=1
PYTORCH_USE_OPENMP=1
PYTORCH_USE_FLASH_ATTENTION=1
PYTORCH_USE_MEM_EFF_ATTENTION=1
PYTORCH_USE_DISTRIBUTED=1
PYTORCH_USE_XPU=0
PYTORCH_USE_ROCM=0
PYTORCH_FORCE_CUDA=1
PYTORCH_BUILD_TEST=0
PYTORCH_CMAKE_BUILD_TYPE=Release
PYTORCH_CMAKE_POLICY_VERSION_MINIMUM=3.5

# Flash Attention 4 runtime build dependencies; Torch stays constrained to the local wheel.
FLASH_ATTENTION_CUTLASS_DSL_REQUIREMENT='nvidia-cutlass-dsl[cu13]==4.6.0.dev0'
FLASH_ATTENTION_EINOPS_REQUIREMENT=einops
FLASH_ATTENTION_TYPING_EXTENSIONS_REQUIREMENT=typing_extensions
FLASH_ATTENTION_TVM_FFI_REQUIREMENT='apache-tvm-ffi>=0.1.12,<0.2'
FLASH_ATTENTION_TORCH_C_DLPACK_REQUIREMENT=torch-c-dlpack-ext
FLASH_ATTENTION_QUACK_KERNELS_REQUIREMENT='quack-kernels>=0.5.3'

# Torchvision build dependencies, codec paths, and CMake feature switches.
VISION_PILLOW_REQUIREMENT='pillow>=10.3.0'
VISION_GDOWN_REQUIREMENT='gdown>=4.7.3'
VISION_SCIPY_REQUIREMENT=scipy
VISION_USE_NATIVE_ARCH=1
VISION_USE_CUDA=1
VISION_USE_CUDNN=1
VISION_USE_XPU=0
VISION_USE_ROCM=0
VISION_USE_GPU_VIDEO_DECODER=1
VISION_USE_CPU_VIDEO_DECODER=1
VISION_USE_PNG=1
VISION_USE_JPEG=1
VISION_USE_WEBP=1
VISION_USE_NVJPEG=1
VISION_FORCE_CUDA=1
VISION_BUILD_TEST=0
VISION_CMAKE_BUILD_TYPE=Release
VISION_CMAKE_POLICY_VERSION_MINIMUM=3.5
VISION_INCLUDE="$NVCODEC_HOME/include"
VISION_LIBRARY="$NVCODEC_HOME/lib"

# Torchaudio CMake feature switches.
AUDIO_USE_CUDA=1
AUDIO_FORCE_CUDA=1
AUDIO_BUILD_TEST=0
AUDIO_CMAKE_BUILD_TYPE=Release

# Final FA4 verification matrix and numerical comparison tolerances.
VERIFY_FA4_DTYPES="float16 bfloat16"
VERIFY_FA4_BATCH_SIZE=1
VERIFY_FA4_SEQUENCE_LENGTH=32
VERIFY_FA4_HEADS=8
VERIFY_FA4_HEAD_DIM=64
VERIFY_FA4_ALLOWED_HEAD_DIMS="64"
VERIFY_FA4_MAX_TENSOR_ELEMENTS=8388608
VERIFY_FA4_RTOL=2e-2
VERIFY_FA4_ATOL=2e-2
